{
  "name": "momo-todo",
  "private": true,
  "version": "1.0.0",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
  "appId": "com.momo.todo",
  "productName": "MomoTodo",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron.cjs",
    "preload.cjs",
    "src/assets/**/*",
    "node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "build/icon.ico",
      "to": "icon.ico"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "nsis": {
  "oneClick": false,
  "allowToChangeInstallationDirectory": true,
  "createDesktopShortcut": true,
  "createStartMenuShortcut": true,
  "shortcutName": "MomoTodo"
}
},
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^7.0.0",
    "@dnd-kit/utilities": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}